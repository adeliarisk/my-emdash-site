---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../layouts/Base.astro";
import Hero from "../components/close/Hero.astro";
import IconFeatureGrid from "../components/close/IconFeatureGrid.astro";
import AlternatingRow from "../components/close/AlternatingRow.astro";
import CtaBand from "../components/close/CtaBand.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 3,
});
Astro.cache.set(cacheHint);

const postsWithTags = await Promise.all(
	posts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		const bylines = post.data.bylines ?? [];
		return {
			post,
			tags: tags.map((t) => ({ slug: t.slug, label: t.label })),
			bylines,
		};
	})
);

const whatWeOffer = [
	{
		iconImage:
			"https://adeliarisk.com/wp-content/uploads/2026/02/we-work-with-your-team.svg",
		title: "Security Compliance",
		description:
			"Navigating compliance with regulations like SEC, HIPAA, CMMC, FINRA, SOC 2, NIST, CIS, ISO27001, and NYDFS is complex. Rely on our expertise to avoid fines, prevent penalties, and keep your business secure.",
	},
	{
		iconImage:
			"https://adeliarisk.com/wp-content/uploads/2025/09/Group-1-1.png",
		title: "Advanced Threat Protection",
		description:
			"In-depth cybersecurity gap assessments, thorough security evaluations, cloud security audits, detailed vulnerability scans, extensive training modules, and user security tests. We offer it all — ensuring your business is robust and resilient.",
	},
	{
		iconImage:
			"https://adeliarisk.com/wp-content/uploads/2026/02/vciso-ria-security-model.svg",
		title: "Flexible Expertise",
		description:
			"Crafting customized approaches, drawing upon certified professionals, without the need to expand your team. We help you unravel complex frameworks and collaborate closely to keep your organization protected from potential threats and evolving regulations.",
	},
];

const industries = [
	{
		title: "Wealth Management Firms",
		body: "Preparing for an SEC audit and responding to their detailed demand letters can be daunting, and the stakes are high. RIAs of all sizes are prime hacker targets due to their control of considerable funds. Even with the support of IT firms, we find that most RIAs are lacking 50-75% of the cybersecurity controls they need.",
		image:
			"https://adeliarisk.com/wp-content/uploads/2025/09/financial-dashboard-security-risk-compliance.webp",
		alt: "Team analyzing financial security dashboard showing AUM, compliance metrics, and risk alerts",
		cta: { label: "Learn more", href: "/pages/ria-cybersecurity-services" },
	},
	{
		title: "DoD Contractors",
		body: "Manufacturing companies that sell directly or indirectly to the DoD may lose significant revenue if they're not CMMC-ready. This isn't hypothetical — we often see manufacturing firms with competent IT help fall short on 50-75% of the CMMC requirements. We translate the controls into an ongoing program, not a one-time audit scramble.",
		image:
			"https://adeliarisk.com/wp-content/uploads/2025/09/compliance-regulations-audit-team-business.webp",
		alt: "Business leader presenting compliance requirements to a team in an industrial facility",
		cta: { label: "Learn more", href: "#" },
		reverse: true,
	},
	{
		title: "Software and Service Firms Seeking SOC 2",
		body: "Getting ready for a SOC 2 audit requires a big jump up in your IT and security tools and processes. The CPA firms that perform the audits will dive deep into your systems to make sure you do what you say, and say what you do. We can help you defend revenue and get new clients by passing a SOC 2 audit with confidence.",
		image:
			"https://adeliarisk.com/wp-content/uploads/2025/09/security-report-team-soc2-readiness.webp",
		alt: "Diverse team reviewing a security report together — SOC 2 readiness",
		cta: { label: "Learn more", href: "#" },
	},
	{
		title: "Healthcare Companies",
		body: "Avoid a spot on the HIPAA Wall of Shame. \"Hacking/IT Incident\" accounts for 68% of healthcare breaches, affecting both big and small firms. The HHS's 86-point HIPAA IT security checklist guides healthcare organizations to protect their business and patient data. We help you get ready and stay ready.",
		image:
			"https://adeliarisk.com/wp-content/uploads/2025/09/healthcare-secure-login-hipaa-protection.webp",
		alt: "Healthcare worker using a secure login on a tablet to protect patient data",
		cta: { label: "Learn more", href: "#" },
		reverse: true,
	},
];
---

<Base
	title="Adelia Risk — Expert Fractional & Virtual CISO Solutions"
	description="Adelia Risk provides flexible cybersecurity solutions tailored to businesses ranging from 10 to 300 employees — compliance, threat protection, and fractional CISO expertise."
>
	<Hero
		title="Expert Fractional & Virtual CISO Solutions"
		subtitle="We provide flexible cybersecurity solutions tailored to businesses ranging from 10 to 300 employees, assisting them in achieving regulatory compliance, countering potential threats, and strengthening their security defense."
		ctaLabel="Learn about our vCISO services"
		ctaHref="#what-we-offer"
		align="center"
	/>

	<section class="home-trustbar ar-section-tight">
		<div class="ar-container">
			<p class="home-trustbar-label">Trusted by Leading Companies</p>
			<div class="home-trustbar-grid">
				{[
					{
						src: "https://adeliarisk.com/wp-content/uploads/2025/07/SFSA_logo_bnw.webp",
						alt: "SFSA",
					},
					{
						src: "https://adeliarisk.com/wp-content/uploads/2025/07/Jenner-logo.webp",
						alt: "Jenner",
					},
					{
						src: "https://adeliarisk.com/wp-content/uploads/2025/07/Physician-Logo.webp",
						alt: "Physician",
					},
					{
						src: "https://adeliarisk.com/wp-content/uploads/2025/07/Parsons-Logo.webp",
						alt: "Parsons",
					},
				].map((logo) => (
					<div class="home-trustbar-logo">
						<img src={logo.src} alt={logo.alt} loading="lazy" />
					</div>
				))}
			</div>
		</div>
	</section>

	<div id="what-we-offer">
		<IconFeatureGrid
			title="What We Offer"
			features={whatWeOffer}
			columns={3}
			tinted
		/>
	</div>

	<section class="home-industries-header ar-section-tight">
		<div class="ar-container-narrow" style="text-align: center;">
			<span class="ar-eyebrow">In-Demand Expertise</span>
			<h2 class="home-section-title">
				Fractional CISO and vCISO Clients We Typically Serve
			</h2>
			<p class="home-section-lead">
				We work across heavily regulated industries where the stakes are high.
			</p>
		</div>
	</section>

	{industries.map((ind) => (
		<AlternatingRow
			title={ind.title}
			body={ind.body}
			image={ind.image}
			imageAlt={ind.alt}
			ctaLabel={ind.cta.label}
			ctaHref={ind.cta.href}
			reverse={ind.reverse}
		/>
	))}

	<AlternatingRow
		title="About Josh Ablett"
		body="Josh Ablett is a skilled cybersecurity expert with over fourteen years of experience. He has worked on major projects for companies like HP and Bottomline, and has successfully dealt with audits and complex regulations such as SEC, HIPAA, and NIST. With a background as a senior leader at the Royal Bank of Scotland, Josh now leads the team at Adelia Risk, where they're working to redefine how we protect ourselves online."
		image="https://adeliarisk.com/wp-content/uploads/2025/07/JA-Headshot-Shingles-Goliwog-Square.webp"
		imageAlt="Headshot of Josh Ablett, Founder and CISO of Adelia Risk"
		ctaLabel="Read our story"
		ctaHref="#"
		tinted
	/>

	<CtaBand
		title="Need something else?"
		subtitle="Cybersecurity is a spectrum. If you don't see your industry or your situation above, we probably still cover it — reach out and tell us what you need."
		ctaLabel="Book a Call"
		ctaHref="#"
	/>

	{postsWithTags.length > 0 && (
		<section class="home-posts ar-section">
			<div class="ar-container">
				<header class="home-posts-header">
					<span class="ar-eyebrow">From the Blog</span>
					<h2 class="home-section-title">Latest Posts</h2>
				</header>
				<div class="home-posts-grid">
					{postsWithTags.map(({ post, tags, bylines }) => (
						<PostCard
							title={post.data.title ?? "Untitled"}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/posts/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags}
							bylines={bylines}
						/>
					))}
				</div>
			</div>
		</section>
	)}

	<CtaBand
		title="Do you think we might be a good match?"
		subtitle="Book a 30-minute consultation and we'll walk through your situation, tell you where you stand, and outline exactly what we'd do if you hired us."
		ctaLabel="Book Your Consultation"
		ctaHref="#"
	/>
</Base>

<style>
	.home-trustbar {
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.home-trustbar-label {
		text-align: center;
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-muted);
		margin: 0 0 2rem;
	}

	.home-trustbar-grid {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: clamp(2rem, 5vw, 4rem);
	}

	.home-trustbar-logo {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 56px;
		opacity: 0.6;
		filter: grayscale(100%);
		transition: opacity 200ms ease, filter 200ms ease;
	}

	.home-trustbar-logo:hover {
		opacity: 1;
		filter: grayscale(0%);
	}

	.home-trustbar-logo img {
		max-height: 100%;
		width: auto;
		max-width: 180px;
		object-fit: contain;
	}

	.home-industries-header {
		padding-bottom: 0 !important;
	}

	.home-section-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3vw, 2.625rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0 0 1rem;
		font-weight: 700;
	}

	.home-section-lead {
		font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.home-posts-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.home-posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	@media (max-width: 860px) {
		.home-posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.home-posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
