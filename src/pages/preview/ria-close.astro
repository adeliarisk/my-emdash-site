---
import Base from "../../layouts/Base.astro";
import Hero from "../../components/close/Hero.astro";
import IconFeatureGrid from "../../components/close/IconFeatureGrid.astro";
import StatsRow from "../../components/close/StatsRow.astro";
import CtaBand from "../../components/close/CtaBand.astro";
import "../../styles/variant-close.css";

// Content is taken verbatim from adeliarisk.com/ria-cybersecurity-services/
// No homepage content — this is an RIA-only page.

const objections = [
	{
		title: '"We already have IT support"',
		description:
			"IT companies make mistakes. They miss a security setting. They forget to enable MFA on a new account. They configure email wrong. Those mistakes lead to breaches. And when something goes wrong, it's your liability, not theirs. We double-check everything and catch the gaps before hackers do.",
	},
	{
		title: '"We\'re too small to be targeted"',
		description:
			"That's exactly what makes you a target. Hackers know you don't have a 50-person security team like the big banks. They know you have access to millions in client assets. And they know that one successful wire fraud pays better than ransoming a hundred small businesses. Small doesn't mean safe. It means easier.",
	},
	{
		title: '"Our compliance consultant handles security"',
		description:
			"Your compliance consultant makes sure your ADV is accurate and you're following custody rules. But they're not monitoring your email for spoofing attempts at 2am. They're not running penetration tests on your systems. Compliance and security overlap, but they're not the same thing. Adelia Risk handles the RIA cybersecurity services so your compliance consultant can do what they do best.",
	},
	{
		title: '"Schwab/Fidelity handles the security"',
		description:
			"Your custodian secures their systems, not yours. When a hacker compromises your email and sends a wire request that looks legitimate, that wire goes through. The custodian isn't liable. They followed a request that came from your firm. You are liable.",
	},
];

const reasons = [
	{
		// target icon
		icon: "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 14a4 4 0 1 1 4-4 4 4 0 0 1-4 4zm0 2a6 6 0 1 0-6-6 6 6 0 0 0 6 6z",
		title: "RIA-Specific Expertise",
		description:
			"We're not general-purpose cybersecurity consultants who also work with dentist offices and restaurants. We specialize in heavily regulated companies like SEC-registered investment advisors and wealth management firms. We understand the ADV Part 2A requirements, custodian relationships, and why \"my Schwab rep said we needed cyber insurance\" isn't actually a security strategy.",
	},
	{
		// calendar-clock
		icon: "M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zM12 14v3l2 1",
		title: "vCISO RIA Security Model (Not Hourly Billing)",
		description:
			"You get a dedicated Virtual CISO for a predictable monthly fee. No surprise invoices. No nickel-and-diming for \"extra\" calls. We know your firm, know your people, and are available when you need them (even in the middle of the night). Not just when the hourly clock is running.",
	},
	{
		// users
		icon: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z",
		title: "We Work With Your Team",
		description:
			"We're not here to fire your IT provider, sell you our products, or tell your compliance consultant they're doing it wrong. We integrate with your existing team and fill the gaps. Your IT team guys handle support. We handle cybersecurity for wealth management firms. Everyone stays in their lane to provide complete oversight of your security.",
	},
	{
		// clipboard-check
		icon: "M9 2h6a1 1 0 0 1 1 1v2H8V3a1 1 0 0 1 1-1zM8 5H6a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 13l2 2 4-4",
		title: "Audit-Ready Documentation",
		description:
			"When the SEC examiner shows up, you'll have the cybersecurity compliance for RIAs they're looking for. Policies, procedures, training records, testing documentation, incident response plans. Nothing is scrambled together the night before. Everything is maintained and current throughout the year.",
	},
];

const results = [
	{
		before: "35%",
		after: "100%",
		label: "From \"we think we're secure\" to SEC examination ready",
		description:
			"This wealth management firm started with only 35% of SEC-expected security controls documented. Month by month, our vCISO team implemented controls, configured tools, and built documentation. Result: passed their SEC examination with zero RIA cybersecurity deficiencies cited.",
	},
	{
		before: "247",
		after: "24",
		label: "Security holes down to 24",
		description:
			"This RIA had 247 vulnerabilities across their systems. 18 were critical. Our team prioritized the critical and high-severity issues first, implementing fixes while documenting Plans of Action for the rest. Result: all critical vulnerabilities eliminated, remaining items documented with SEC-ready remediation timelines.",
	},
	{
		before: "28%",
		after: "4%",
		label: "Your biggest risk: your own team",
		description:
			"Month 1: 28% of employees clicked phishing emails. Today: 4% click rate, and 71% now actively report suspicious emails instead of ignoring them. The SEC expects security awareness training. We make it stick.",
	},
];

const hackersWant = [
	"Account numbers for high-net-worth individuals",
	"Social Security numbers and tax returns",
	"Wire transfer capabilities to custodian accounts",
	"Access to millions (sometimes billions) in client assets",
	"Trusted relationships with wealthy clients",
];

const secWatchFor = [
	"Written RIA cybersecurity policies and procedures",
	"Incident response plans (actually tested, not just documented)",
	"Third-party vendor oversight",
	"Employee training records",
	"Evidence of ongoing security monitoring",
];
---

<Base
	title="RIA Cybersecurity Services"
	description="Expert RIA cybersecurity services for SEC-registered advisors — from vCISO support to exam-ready documentation."
>
	<div class="variant-close">
		<Hero
			eyebrow="For SEC-Registered Advisors"
			title="RIA Cybersecurity Services for Wealth Management Firms"
			subtitle="Stop worrying about wire fraud, SEC examinations, and what if something happens to client data. We handle it."
			ctaLabel="Get Your Free RIA Cybersecurity Assessment"
			ctaHref="#"
			secondaryCtaLabel="See How We Work"
			secondaryCtaHref="#why"
		/>

		<section class="close-section close-section-tinted">
			<div class="close-container-narrow" style="text-align: center;">
				<p style="font-size: var(--close-lead); line-height: 1.7; color: var(--close-ink-soft); margin: 0;">
					Adelia Risk is a cybersecurity firm that handles RIA cybersecurity services for SEC-registered advisors
					and wealth management firms. We build your security program, manage your tools, and get you
					examination-ready. We've helped RIAs go from "we think we're secure" to confidently passing SEC
					examinations without losing their minds (or their clients).
				</p>
			</div>
		</section>

		<IconFeatureGrid
			eyebrow="You're Not a Cybersecurity Expert"
			title="You've probably told yourself one of these"
			subtitle="The four things RIAs say when they explain why they haven't built a real cybersecurity program. Here's why each one misses the point."
			features={objections}
			columns={2}
		/>

		<!-- Dark list section: You Have a Target on Your Back -->
		<section class="close-section" style="background: var(--close-grad-hero-mesh); color: var(--close-white); position: relative;">
			<div class="close-container">
				<div class="c-target-grid">
					<div class="c-target-copy">
						<span class="close-eyebrow">Why RIAs Are In The Crosshairs</span>
						<h2 class="c-target-title">You Have a Target on Your Back. Here's Why.</h2>
						<p class="c-target-body">
							RIAs and wealth management firms are among the most targeted businesses in the country
							because they control over $145 trillion in assets. You aren't targeted because you're doing
							something wrong. You're targeted because you're doing something valuable.
						</p>
					</div>
					<div class="c-target-list-wrap">
						<h3 class="c-target-list-title">You Have Everything Hackers Want</h3>
						<ul class="c-target-list">
							{hackersWant.map((item) => (
								<li>
									<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
										<circle cx="10" cy="10" r="10" fill="rgba(255,255,255,0.12)"/>
										<path d="M6 10l3 3 5-6" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
									<span>{item}</span>
								</li>
							))}
						</ul>
						<p class="c-target-footer">
							A single successful RIA cyberattack can yield more than dozens of attacks on regular
							businesses. Hackers know this.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- SEC Is Watching section, tinted -->
		<section class="close-section close-section-tinted">
			<div class="close-container">
				<div class="c-sec-grid">
					<div class="c-sec-copy">
						<span class="close-eyebrow">Regulatory Pressure</span>
						<h2 class="c-sec-title">The SEC Is Watching</h2>
						<p class="c-sec-body">
							The SEC created a new Cyber and Emerging Technologies Unit (CETU) in February 2025. One of
							its priority areas is "regulated entities' compliance with cybersecurity rules and regulations,
							including rules relating to the protection of customer information."
						</p>
						<p class="c-sec-body">
							SEC examinations can result in deficiency letters if your cybersecurity program doesn't meet
							expectations. That can mean enforcement actions, fines, and reputational damage. Our RIA
							cybersecurity services get you prepared.
						</p>
					</div>
					<div class="c-sec-card">
						<h3 class="c-sec-card-title">What SEC examiners look for</h3>
						<ul class="c-sec-list">
							{secWatchFor.map((item) => (
								<li>
									<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
										<circle cx="10" cy="10" r="10" fill="#354ff5" fill-opacity="0.12"/>
										<path d="M6 10l3 3 5-6" stroke="#354ff5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</section>

		<IconFeatureGrid
			eyebrow="Why Wealth Management Firms Choose Adelia"
			title="An RIA cybersecurity partner, not a vendor"
			subtitle="Four things that separate us from general-purpose cybersecurity consultants and hourly IT providers."
			features={reasons}
			columns={2}
			tinted={false}
		/>

		<StatsRow
			eyebrow="Proven Cybersecurity Results"
			title="Outcomes our clients actually see"
			stats={results}
			dark
		/>

		<CtaBand
			eyebrow="Ready When You Are"
			title="Protect Your Wealth Management Firm"
			subtitle="Prices start at a few hundred dollars a month for small clients and scale competitively for larger and more complex companies. Let's book a consultation to show how we can help."
			ctaLabel="Book a consultation"
			ctaHref="#"
		/>
	</div>
</Base>

<style>
	.c-target-grid,
	.c-sec-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: start;
	}

	.c-target-title,
	.c-sec-title {
		font-family: var(--close-font-heading);
		font-size: var(--close-h2);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 0 0 1.25rem;
		font-weight: 700;
	}

	.c-target-title {
		color: var(--close-white);
	}

	.c-target-body {
		font-size: var(--close-lead);
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.82);
		margin: 0;
	}

	.c-target-list-wrap {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: var(--close-radius-card);
		padding: 2rem 2.25rem;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.c-target-list-title {
		font-family: var(--close-font-heading);
		font-size: 1.25rem;
		color: var(--close-white);
		margin: 0 0 1.25rem;
		font-weight: 700;
	}

	.c-target-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.c-target-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		font-size: var(--close-body);
		color: rgba(255, 255, 255, 0.92);
	}

	.c-target-list svg {
		flex-shrink: 0;
		margin-top: 0.15rem;
	}

	.c-target-footer {
		font-size: var(--close-small);
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.72);
		font-style: italic;
		margin: 0;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
	}

	.c-sec-title {
		color: var(--close-ink);
	}

	.c-sec-body {
		font-size: var(--close-body);
		line-height: 1.7;
		color: var(--close-ink-soft);
		margin: 0 0 1.25rem;
	}

	.c-sec-card {
		background: var(--close-white);
		border-radius: var(--close-radius-card);
		padding: 2.25rem 2rem;
		box-shadow: var(--close-shadow-card);
	}

	.c-sec-card-title {
		font-family: var(--close-font-heading);
		font-size: 1.25rem;
		color: var(--close-ink);
		margin: 0 0 1.25rem;
		font-weight: 700;
	}

	.c-sec-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.c-sec-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		font-size: var(--close-body);
		color: var(--close-ink);
		line-height: 1.5;
	}

	.c-sec-list svg {
		flex-shrink: 0;
		margin-top: 0.15rem;
	}

	@media (max-width: 860px) {
		.c-target-grid,
		.c-sec-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
