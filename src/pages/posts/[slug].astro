---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import ChecklistCta from "../../components/close/ChecklistCta.astro";
import { getReadingTime } from "../../utils/reading-time";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);

const seo = getSeoMeta(post, {
	siteTitle: "Adelia Risk",
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

const tags = await getEntryTerms("posts", post.data.id, "tag");
const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);

const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const postTags = await getEntryTerms("posts", p.data.id, "tag");
		const postBylines = p.data.bylines ?? [];
		return { post: p, tags: postTags, bylines: postBylines };
	})
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;

/* Slug-specific metadata overrides. When a post is migrated from an
 * external source the CMS-stored publishedAt reflects the import date,
 * not the original publish date, and bylines aren't always set up via
 * the CLI. These overrides patch the display so migrated posts render
 * with their original metadata without touching the underlying data. */
const METADATA_OVERRIDES: Record<
	string,
	{
		publishDate?: string;
		author?: string;
		authorTitle?: string;
		authorAvatar?: string;
	}
> = {
	"how-online-banking-security-protects-your-accounts": {
		publishDate: "February 20, 2026",
		author: "Josh Ablett",
		authorTitle: "Founder & CISO",
		authorAvatar: "/_emdash/api/media/file/01KNNC9M01ZCVQ99DPGJCRHC55.webp",
	},
};
const override = METADATA_OVERRIDES[slug] || {};
const displayDate = override.publishDate || publishDate;
const displayAuthor = override.author;
const displayAuthorTitle = override.authorTitle;
const displayAuthorAvatar = override.authorAvatar;

/* -------------------------------------------------------------------------
   Split the Portable Text content into renderable segments so we can insert
   custom components (like the ChecklistCta form replacement) where the
   source article had inline forms. We look for specific H2s that were the
   form headers on the original post and swap them for a styled CTA card.

   Segment types:
     - { type: "pt", blocks: [...] }       — pass to <PortableText />
     - { type: "checklist", title, body }  — render <ChecklistCta />
------------------------------------------------------------------------- */
type Segment =
	| { type: "pt"; blocks: unknown[] }
	| { type: "checklist"; title: string; body: string };

const FORM_HEADERS = new Set([
	"Want the Editable Checklist?",
	"Want the Complete Banking Security Checklist?",
]);

function blockText(block: any): string {
	if (!block || block._type !== "block") return "";
	return (block.children ?? [])
		.map((c: any) => c?.text ?? "")
		.join("")
		.trim();
}

const rawContent = (post.data.content ?? []) as any[];
const segments: Segment[] = [];
let buffer: unknown[] = [];

function flush() {
	if (buffer.length > 0) {
		segments.push({ type: "pt", blocks: buffer });
		buffer = [];
	}
}

for (let i = 0; i < rawContent.length; i++) {
	const block = rawContent[i];
	if (block?._type === "block" && block.style === "h2") {
		const text = blockText(block);
		if (FORM_HEADERS.has(text)) {
			flush();
			// Consume the next block if it's the explanatory paragraph
			let body = "";
			const next = rawContent[i + 1];
			if (next?._type === "block" && next.style === "normal") {
				body = blockText(next);
				i++;
			}
			segments.push({ type: "checklist", title: text, body });
			continue;
		}
	}
	buffer.push(block);
}
flush();
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="post">
		<header class="post-hero">
			<div class="post-hero-bg" aria-hidden="true"></div>
			<div class="post-hero-inner ar-container">
				{tags.length > 0 && (
					<div class="post-hero-tags">
						{tags.slice(0, 2).map((t) => (
							<a href={`/tag/${t.slug}`} class="post-hero-tag">{t.label}</a>
						))}
					</div>
				)}
				<h1 class="post-hero-title" {...post.edit.title}>{post.data.title}</h1>
				{post.data.excerpt && (
					<p class="post-hero-subtitle">{post.data.excerpt}</p>
				)}
				<div class="post-hero-meta">
					{bylines.length > 0 ? (
						<div class="post-hero-byline-group">
							{bylines.map((credit) => (
								<div class="post-hero-byline">
									{credit.byline.avatarMediaId ? (
										<img
											src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
											alt={credit.byline.displayName}
											class="post-hero-avatar"
										/>
									) : (
										<div class="post-hero-avatar post-hero-avatar-fallback" aria-hidden="true">
											{credit.byline.displayName.charAt(0)}
										</div>
									)}
									<span class="post-hero-byline-name">{credit.byline.displayName}</span>
								</div>
							))}
						</div>
					) : (
						<div class="post-hero-byline">
							{displayAuthorAvatar ? (
								<img
									src={displayAuthorAvatar}
									alt={displayAuthor || "Author"}
									class="post-hero-avatar"
								/>
							) : (
								<div class="post-hero-avatar post-hero-avatar-fallback" aria-hidden="true">
									{displayAuthor ? displayAuthor.charAt(0) : "A"}
								</div>
							)}
							<div class="post-hero-byline-info">
								<span class="post-hero-byline-name">{displayAuthor || "Adelia Risk"}</span>
								{displayAuthorTitle && (
									<span class="post-hero-byline-title">{displayAuthorTitle}</span>
								)}
							</div>
						</div>
					)}
					{displayDate && (
						<>
							<span class="post-hero-dot" aria-hidden="true"></span>
							<time class="post-hero-date">{displayDate}</time>
						</>
					)}
					<span class="post-hero-dot" aria-hidden="true"></span>
					<span class="post-hero-read">{readingTime} min read</span>
				</div>
			</div>
		</header>

		{post.data.featured_image && (
			<div class="post-featured ar-container" {...post.edit.featured_image}>
				<div class="post-featured-wrap">
					<Image
						image={post.data.featured_image}
						loading="eager"
						fetchpriority="high"
						decoding="async"
					/>
				</div>
			</div>
		)}

		<div class="post-body ar-container">
			<div class="post-grid">
				<div class="post-main">
					<div class="post-content">
						{segments.map((segment) =>
							segment.type === "pt" ? (
								<PortableText value={segment.blocks} />
							) : (
								<ChecklistCta title={segment.title} subtitle={segment.body} />
							)
						)}
					</div>

					<div class="post-share">
						<span class="post-share-label">Share</span>
						<a
							href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`${Astro.url.origin}/posts/${slug}`)}`}
							class="post-share-btn"
							aria-label="Share on LinkedIn"
							target="_blank"
							rel="noopener"
						>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" />
							</svg>
						</a>
						<a
							href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(`${Astro.url.origin}/posts/${slug}`)}&text=${encodeURIComponent(post.data.title)}`}
							class="post-share-btn"
							aria-label="Share on X"
							target="_blank"
							rel="noopener"
						>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
							</svg>
						</a>
						<a
							href={`mailto:?subject=${encodeURIComponent(post.data.title)}&body=${encodeURIComponent(`${Astro.url.origin}/posts/${slug}`)}`}
							class="post-share-btn"
							aria-label="Share by email"
						>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
								<polyline points="22,6 12,13 2,6"/>
							</svg>
						</a>
					</div>

					<div class="post-comments">
						<Comments collection="posts" contentId={post.data.id} threaded />
						<CommentForm collection="posts" contentId={post.data.id} />
					</div>
				</div>

				<aside class="post-toc-col">
					<div class="post-toc-sticky">
						<nav class="post-toc" aria-label="Table of contents">
							<h4 class="post-toc-title">On This Page</h4>
							<div class="post-toc-content" id="post-toc-content"></div>
						</nav>
					</div>
				</aside>
			</div>
		</div>
	</article>

	{otherPostsWithTags.length > 0 && (
		<section class="post-more">
			<div class="ar-container">
				<header class="post-more-header">
					<span class="ar-eyebrow">Keep Reading</span>
					<h2 class="post-more-title">More from the blog</h2>
				</header>
				<div class="post-more-grid">
					{otherPostsWithTags.map(({ post: p, tags: postTags, bylines: postBylines }) => (
						<PostCard
							title={p.data.title}
							excerpt={p.data.excerpt}
							featuredImage={p.data.featured_image}
							href={`/posts/${p.id}`}
							date={p.data.publishedAt ?? undefined}
							readingTime={getReadingTime(p.data.content)}
							tags={postTags.map((t) => ({ slug: t.slug, label: t.label }))}
							bylines={postBylines}
						/>
					))}
				</div>
			</div>
		</section>
	)}

	<script>
		// Build a table of contents from h2/h3 headings inside .post-content
		function buildToc() {
			const content = document.querySelector(".post-content");
			const tocContainer = document.getElementById("post-toc-content");
			if (!content || !tocContainer) return;

			const headings = content.querySelectorAll("h2, h3");
			if (headings.length < 2) {
				const toc = document.querySelector(".post-toc") as HTMLElement | null;
				if (toc) toc.style.display = "none";
				return;
			}

			const list = document.createElement("ol");
			list.className = "post-toc-list";

			headings.forEach((heading, index) => {
				if (!heading.id) heading.id = `heading-${index}`;

				const li = document.createElement("li");
				li.className =
					heading.tagName === "H3" ? "post-toc-item post-toc-item--sub" : "post-toc-item";

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = "post-toc-link";
				link.textContent = heading.textContent;

				li.appendChild(link);
				list.appendChild(li);
			});

			tocContainer.appendChild(list);

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const link = tocContainer.querySelector(`a[href="#${id}"]`);
						if (link) {
							if (entry.isIntersecting) {
								tocContainer
									.querySelectorAll(".post-toc-link")
									.forEach((l) => l.classList.remove("is-active"));
								link.classList.add("is-active");
							}
						}
					});
				},
				{ rootMargin: "-120px 0px -70% 0px" }
			);
			headings.forEach((h) => observer.observe(h));
		}
		buildToc();
	</script>
</Base>

<style>
	/* ===== HERO ===== */
	.post-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.5rem, 5vw, 4rem);
		color: var(--color-on-accent);
	}

	.post-hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		background: var(--gradient-hero);
	}

	.post-hero-bg::after {
		content: "";
		position: absolute;
		inset: 0;
		background-image: radial-gradient(
			circle at 1px 1px,
			rgba(255, 255, 255, 0.06) 1px,
			transparent 0
		);
		background-size: 24px 24px;
		mask-image: linear-gradient(180deg, #000 0%, transparent 85%);
		-webkit-mask-image: linear-gradient(180deg, #000 0%, transparent 85%);
	}

	.post-hero-inner {
		position: relative;
		z-index: 1;
		max-width: 860px;
		text-align: center;
	}

	.post-hero-tags {
		display: flex;
		gap: 0.625rem;
		justify-content: center;
		margin-bottom: 1.5rem;
	}

	.post-hero-tag {
		display: inline-block;
		padding: 0.5rem 1.125rem;
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--color-on-accent);
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		transition: background 180ms ease;
	}

	.post-hero-tag:hover {
		background: rgba(255, 255, 255, 0.2);
		color: var(--color-on-accent);
	}

	.post-hero-title {
		font-family: var(--font-heading);
		font-size: clamp(2rem, 4.5vw, 3.5rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--color-on-accent);
		margin: 0 0 1.5rem;
		font-weight: 700;
	}

	.post-hero-subtitle {
		font-size: clamp(1.0625rem, 1.6vw, 1.3125rem);
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.85);
		margin: 0 0 2rem;
		max-width: 720px;
		margin-left: auto;
		margin-right: auto;
	}

	.post-hero-meta {
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		padding: 0.75rem 1.25rem;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 999px;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.85);
		flex-wrap: wrap;
		justify-content: center;
	}

	.post-hero-byline-group {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.post-hero-byline {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.post-hero-avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		object-fit: cover;
	}

	.post-hero-avatar-fallback {
		background: var(--gradient-cta);
		color: var(--color-on-accent);
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-heading);
		font-size: 0.875rem;
		font-weight: 700;
	}

	.post-hero-byline-info {
		display: flex;
		flex-direction: column;
		line-height: 1.2;
	}

	.post-hero-byline-name {
		font-weight: 600;
		color: var(--color-on-accent);
	}

	.post-hero-byline-title {
		font-size: 0.75rem;
		color: rgba(255, 255, 255, 0.6);
		font-weight: 400;
	}

	.post-hero-dot {
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.4);
	}

	/* ===== FEATURED IMAGE ===== */
	.post-featured {
		position: relative;
		z-index: 2;
		margin-top: clamp(2.5rem, 5vw, 4rem);
		margin-bottom: clamp(3rem, 5vw, 5rem);
	}

	.post-featured-wrap {
		max-width: 1100px;
		margin: 0 auto;
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow:
			0 30px 60px rgba(18, 38, 58, 0.2),
			0 10px 20px rgba(18, 38, 58, 0.12);
	}

	.post-featured-wrap :global(img) {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 3 / 2;
		object-fit: cover;
	}

	/* ===== BODY LAYOUT ===== */
	.post-body {
		margin-bottom: clamp(4rem, 8vw, 7rem);
	}

	.post-grid {
		display: grid;
		grid-template-columns: minmax(0, 760px) 260px;
		gap: clamp(2rem, 4vw, 4rem);
		justify-content: center;
	}

	.post-toc-col {
		display: block;
	}

	.post-toc-sticky {
		position: sticky;
		top: calc(var(--nav-height) + 1.5rem);
	}

	.post-toc {
		padding: 1.75rem;
		background: var(--color-bg-subtle);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border-subtle);
	}

	.post-toc-title {
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-muted);
		margin: 0 0 1rem;
	}

	.post-toc-content :global(.post-toc-list) {
		list-style: none;
		padding: 0;
		margin: 0;
		counter-reset: toc;
	}

	.post-toc-content :global(.post-toc-item) {
		counter-increment: toc;
		margin-bottom: 0.25rem;
		position: relative;
	}

	.post-toc-content :global(.post-toc-item--sub) {
		padding-left: 1.25rem;
	}

	.post-toc-content :global(.post-toc-link) {
		display: block;
		padding: 0.5rem 0;
		font-size: 0.875rem;
		line-height: 1.4;
		color: var(--color-text-secondary);
		text-decoration: none;
		border-left: 2px solid transparent;
		padding-left: 0.75rem;
		margin-left: -0.75rem;
		transition: color 180ms ease, border-color 180ms ease;
	}

	.post-toc-content :global(.post-toc-link:hover),
	.post-toc-content :global(.post-toc-link.is-active) {
		color: var(--color-blue);
		border-left-color: var(--color-blue);
		font-weight: 600;
	}

	.post-main {
		min-width: 0;
	}

	/* ===== ARTICLE TYPOGRAPHY ===== */
	.post-content {
		font-size: 1.125rem;
		line-height: 1.75;
		color: var(--color-text);
	}

	.post-content :global(p) {
		margin: 0 0 1.5em;
		color: var(--color-text-secondary);
	}

	.post-content :global(p:first-of-type) {
		font-size: 1.25rem;
		line-height: 1.65;
		color: var(--color-text);
		font-weight: 400;
	}

	.post-content :global(h2) {
		font-family: var(--font-heading);
		font-size: clamp(1.625rem, 2.8vw, 2rem);
		line-height: 1.2;
		letter-spacing: -0.015em;
		color: var(--color-navy);
		margin: 3rem 0 1.25rem;
		font-weight: 700;
		scroll-margin-top: calc(var(--nav-height) + 1rem);
	}

	.post-content :global(h3) {
		font-family: var(--font-heading);
		font-size: 1.4375rem;
		line-height: 1.25;
		color: var(--color-navy);
