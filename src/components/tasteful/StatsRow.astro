---
interface Stat {
	value: string;
	unit?: string;
	label: string;
	description: string;
}

interface Props {
	eyebrow?: string;
	title?: string;
	subtitle?: string;
	stats: Stat[];
	dark?: boolean;
}

const { eyebrow, title, subtitle, stats, dark = false } = Astro.props;
---

<section class={`t-stats t-section ${dark ? "t-section-dark" : ""}`}>
	<div class="t-container">
		{(eyebrow || title || subtitle) && (
			<header class="t-stats-header">
				<div class="t-stats-meta">
					{eyebrow && <span class="t-eyebrow">{eyebrow}</span>}
				</div>
				<div class="t-stats-intro">
					{title && <h2 class="t-stats-title">{title}</h2>}
					{subtitle && <p class="t-lead t-stats-subtitle">{subtitle}</p>}
				</div>
			</header>
		)}
		<hr class="t-rule" />
		<div class="t-stats-grid">
			{stats.map((s, i) => (
				<article class="t-stats-card">
					<div class="t-stats-number-wrap">
						<span class="t-stats-value">{s.value}</span>
						{s.unit && <span class="t-stats-unit">{s.unit}</span>}
					</div>
					<div class="t-stats-meta-block">
						<span class="t-stats-idx">{String(i + 1).padStart(2, "0")}</span>
						<h3 class="t-stats-label">{s.label}</h3>
						<p class="t-stats-desc">{s.description}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.t-stats-header {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: start;
		margin-bottom: 3rem;
	}

	.t-stats-title {
		font-size: var(--t-h2);
		max-width: 720px;
		margin: 0 0 1rem;
	}

	.t-stats-subtitle {
		max-width: 620px;
		margin: 0;
	}

	.t-stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
	}

	.t-stats-card {
		padding: 3rem 2.5rem 3rem 0;
		border-right: 1px solid var(--t-rule-soft);
	}

	.t-section-dark .t-stats-card {
		border-right-color: rgba(247, 243, 236, 0.15);
	}

	.t-stats-card:last-child {
		border-right: none;
		padding-right: 0;
	}

	.t-stats-card:not(:first-child) {
		padding-left: 2.5rem;
	}

	.t-stats-number-wrap {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	.t-stats-value {
		font-family: var(--t-font-display);
		font-size: var(--t-stat);
		line-height: 0.85;
		letter-spacing: -0.04em;
		color: var(--t-ink);
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}

	.t-section-dark .t-stats-value {
		color: var(--t-cream);
	}

	.t-stats-unit {
		font-family: var(--t-font-display);
		font-size: clamp(1.5rem, 3vw, 2.5rem);
		font-weight: 400;
		font-style: italic;
		color: var(--t-accent);
	}

	.t-stats-meta-block {
		border-top: 1px solid var(--t-rule-soft);
		padding-top: 1.25rem;
	}

	.t-section-dark .t-stats-meta-block {
		border-top-color: rgba(247, 243, 236, 0.2);
	}

	.t-stats-idx {
		display: inline-block;
		font-family: var(--t-font-display);
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--t-accent);
		letter-spacing: 0.06em;
		margin-bottom: 0.5rem;
	}

	.t-stats-label {
		font-family: var(--t-font-display);
		font-size: 1.25rem;
		line-height: 1.2;
		color: var(--t-ink);
		margin: 0 0 0.5rem;
		font-weight: 700;
	}

	.t-section-dark .t-stats-label {
		color: var(--t-cream);
	}

	.t-stats-desc {
		font-size: 0.9375rem;
		line-height: 1.55;
		color: var(--t-ink-soft);
		margin: 0;
		max-width: 28ch;
	}

	.t-section-dark .t-stats-desc {
		color: rgba(247, 243, 236, 0.72);
	}

	@media (max-width: 960px) {
		.t-stats-header {
			grid-template-columns: 1fr;
		}
		.t-stats-grid {
			grid-template-columns: 1fr;
		}
		.t-stats-card {
			border-right: none !important;
			border-bottom: 1px solid var(--t-rule-soft);
			padding: 2.5rem 0 !important;
		}
		.t-stats-card:last-child {
			border-bottom: none;
		}
	}
</style>
