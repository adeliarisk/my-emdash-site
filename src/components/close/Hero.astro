---
interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	ctaLabel?: string;
	ctaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
	image?: string;
	imageAlt?: string;
}

const {
	eyebrow,
	title,
	subtitle,
	ctaLabel,
	ctaHref = "#",
	secondaryCtaLabel,
	secondaryCtaHref = "#",
	image,
	imageAlt = "",
} = Astro.props;
---

<section class="c-hero">
	<div class="c-hero-bg" aria-hidden="true"></div>
	<div class="c-hero-inner close-container">
		<div class="c-hero-copy">
			{eyebrow && <span class="close-eyebrow">{eyebrow}</span>}
			<h1 class="c-hero-title">{title}</h1>
			{subtitle && <p class="c-hero-subtitle">{subtitle}</p>}
			{(ctaLabel || secondaryCtaLabel) && (
				<div class="c-hero-ctas">
					{ctaLabel && (
						<a href={ctaHref} class="close-btn close-btn-primary">
							{ctaLabel}
							<svg width="18" height="12" viewBox="0 0 18 12" fill="none" aria-hidden="true">
								<path d="M12 1L17 6M17 6L12 11M17 6H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</a>
					)}
					{secondaryCtaLabel && (
						<a href={secondaryCtaHref} class="close-btn close-btn-ghost">
							{secondaryCtaLabel}
						</a>
					)}
				</div>
			)}
		</div>
		{image && (
			<div class="c-hero-image">
				<img src={image} alt={imageAlt} loading="eager" fetchpriority="high" />
			</div>
		)}
	</div>
</section>

<style>
	.c-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(5rem, 10vw, 9rem) var(--close-gutter) clamp(4rem, 8vw, 7rem);
		color: var(--close-white);
	}

	.c-hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		background: var(--close-grad-hero-mesh);
	}

	.c-hero-bg::after {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.06) 1px, transparent 0);
		background-size: 24px 24px;
		mask-image: linear-gradient(180deg, #000 0%, transparent 80%);
		-webkit-mask-image: linear-gradient(180deg, #000 0%, transparent 80%);
	}

	.c-hero-inner {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
	}

	.c-hero-copy {
		max-width: 680px;
	}

	.c-hero-title {
		font-family: var(--close-font-heading);
		font-size: var(--close-h1);
		line-height: 1.08;
		letter-spacing: -0.02em;
		color: var(--close-white);
		margin: 0 0 1.25rem;
		font-weight: 700;
	}

	.c-hero-subtitle {
		font-size: var(--close-lead);
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.85);
		margin: 0 0 2.25rem;
		max-width: 620px;
	}

	.c-hero-ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.c-hero-image {
		position: relative;
		border-radius: var(--close-radius-card);
		overflow: hidden;
		box-shadow:
			0 30px 60px rgba(0, 0, 0, 0.3),
			0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.c-hero-image img {
		display: block;
		width: 100%;
		height: auto;
	}

	@media (max-width: 860px) {
		.c-hero-inner {
			grid-template-columns: 1fr;
		}
		.c-hero-image {
			max-width: 480px;
			margin: 0 auto;
		}
	}
</style>
