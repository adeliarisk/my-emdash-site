---
interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	ctaLabel?: string;
	ctaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
	image?: string;
	imageAlt?: string;
	align?: "left" | "center";
}

const {
	eyebrow,
	title,
	subtitle,
	ctaLabel,
	ctaHref = "#",
	secondaryCtaLabel,
	secondaryCtaHref = "#",
	image,
	imageAlt = "",
	align = "left",
} = Astro.props;
---

<section class={`c-hero c-hero-align-${align}`}>
	<div class="c-hero-bg" aria-hidden="true"></div>
	<div class={`c-hero-inner ar-container ${image ? "c-hero-has-image" : ""}`}>
		<div class="c-hero-copy">
			{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
			<h1 class="c-hero-title">{title}</h1>
			{subtitle && <p class="c-hero-subtitle">{subtitle}</p>}
			{(ctaLabel || secondaryCtaLabel) && (
				<div class="c-hero-ctas">
					{ctaLabel && (
						<a href={ctaHref} class="ar-btn ar-btn-primary">
							{ctaLabel}
							<svg width="18" height="12" viewBox="0 0 18 12" fill="none" aria-hidden="true">
								<path d="M12 1L17 6M17 6L12 11M17 6H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</a>
					)}
					{secondaryCtaLabel && (
						<a href={secondaryCtaHref} class="ar-btn ar-btn-ghost">
							{secondaryCtaLabel}
						</a>
					)}
				</div>
			)}
		</div>
		{image && (
			<div class="c-hero-image">
				<img src={image} alt={imageAlt} loading="eager" fetchpriority="high" />
			</div>
		)}
	</div>
</section>

<style>
	.c-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(6rem, 11vw, 10rem) 0 clamp(5rem, 9vw, 8rem);
		color: var(--color-on-accent);
	}

	.c-hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		background: var(--gradient-hero);
	}

	.c-hero-bg::after {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: linear-gradient(180deg, #000 0%, transparent 85%);
		-webkit-mask-image: linear-gradient(180deg, #000 0%, transparent 85%);
	}

	.c-hero-inner {
		position: relative;
		z-index: 1;
	}

	.c-hero-has-image {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
	}

	.c-hero-align-center .c-hero-copy {
		margin: 0 auto;
		text-align: center;
	}

	.c-hero-align-center .c-hero-subtitle,
	.c-hero-align-center .c-hero-ctas {
		margin-left: auto;
		margin-right: auto;
	}

	.c-hero-align-center .c-hero-ctas {
		justify-content: center;
	}

	.c-hero-copy {
		max-width: 960px;
	}

	.c-hero-align-center .c-hero-copy {
		max-width: 900px;
	}

	.c-hero-title {
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 5.5vw, 3.4rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--color-on-accent);
		margin: 0 0 1.25rem;
		font-weight: 700;
		overflow-wrap: break-word;
		word-wrap: break-word;
		hyphens: auto;
	}

	.c-hero-subtitle {
		font-size: clamp(1.125rem, 1.6vw, 1.3125rem);
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.85);
		margin: 0 0 2.25rem;
		max-width: 680px;
	}

	.c-hero-ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.c-hero-image {
		position: relative;
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow:
			0 30px 60px rgba(0, 0, 0, 0.3),
			0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.c-hero-image img {
		display: block;
		width: 100%;
		height: auto;
	}

	@media (max-width: 860px) {
		.c-hero-has-image {
			grid-template-columns: 1fr;
		}
		.c-hero-image {
			max-width: 520px;
			margin: 0 auto;
		}
	}

	@media (max-width: 540px) {
		.c-hero-title {
			font-size: 1.75rem !important;
		}
		.c-hero-subtitle {
			font-size: 1rem !important;
		}
	}

	@media (max-width: 420px) {
		.c-hero-title {
			font-size: 1.5rem !important;
		}
	}
</style>
