---
interface Props {
	eyebrow?: string;
	title: string;
	paragraphs: string[];
	listTitle: string;
	items: string[];
}

const { eyebrow, title, paragraphs, listTitle, items } = Astro.props;
---

<section class="c-sec ar-section ar-section-tinted">
	<div class="ar-container">
		<div class="c-sec-grid">
			<div class="c-sec-copy">
				{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
				<h2 class="c-sec-title">{title}</h2>
				{paragraphs.map((p) => (
					<p class="c-sec-body">{p}</p>
				))}
			</div>
			<aside class="c-sec-card">
				<div class="c-sec-card-icon" aria-hidden="true">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 2l9 4v6c0 5-3.8 9.3-9 11-5.2-1.7-9-6-9-11V6l9-4z" />
						<path d="M9 12l2 2 4-4" />
					</svg>
				</div>
				<h3 class="c-sec-card-title">{listTitle}</h3>
				<ul class="c-sec-list">
					{items.map((item) => (
						<li>
							<svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<circle cx="10" cy="10" r="10" fill="#354ff5" fill-opacity="0.12"/>
								<path d="M6 10l3 3 5-6" stroke="#354ff5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</aside>
		</div>
	</div>
</section>

<style>
	.c-sec-grid {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: start;
	}

	.c-sec-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3.2vw, 2.625rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0 0 1.25rem;
		font-weight: 700;
	}

	.c-sec-body {
		font-size: 1.0625rem;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin: 0 0 1.25rem;
	}

	.c-sec-body:last-of-type {
		margin-bottom: 0;
	}

	.c-sec-card {
		background: var(--color-bg);
		border-radius: var(--radius-lg);
		padding: 2.5rem 2.25rem;
		box-shadow: var(--shadow-card);
		position: relative;
	}

	.c-sec-card-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 64px;
		height: 64px;
		border-radius: 16px;
		background: var(--gradient-cta);
		color: var(--color-on-accent);
		margin-bottom: 1.5rem;
		box-shadow: var(--shadow-cta);
	}

	.c-sec-card-title {
		font-family: var(--font-heading);
		font-size: 1.375rem;
		color: var(--color-text);
		margin: 0 0 1.25rem;
		font-weight: 700;
	}

	.c-sec-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.c-sec-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		font-size: 1rem;
		line-height: 1.5;
		color: var(--color-text);
	}

	.c-sec-list svg {
		flex-shrink: 0;
		margin-top: 0.125rem;
	}

	@media (max-width: 860px) {
		.c-sec-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
