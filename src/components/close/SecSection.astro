---
interface Props {
	eyebrow?: string;
	title: string;
	paragraphs: string[];
	listTitle: string;
	items: string[];
}

const { eyebrow, title, paragraphs, listTitle, items } = Astro.props;
---

<section class="c-sec ar-section">
	<div class="ar-container">
		<header class="c-sec-header">
			{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
			<h2 class="c-sec-title">{title}</h2>
		</header>
		<div class="c-sec-grid">
			<div class="c-sec-copy-card">
				{paragraphs.map((p) => (
					<p class="c-sec-body">{p}</p>
				))}
			</div>
			<aside class="c-sec-list-card">
				<h3 class="c-sec-card-title">{listTitle}</h3>
				<ul class="c-sec-list">
					{items.map((item) => (
						<li>
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<rect x="1" y="1" width="18" height="18" rx="4" fill="#354ff5" fill-opacity="0.1" stroke="#354ff5" stroke-width="1.5"/>
								<path d="M6 10l3 3 5-6" stroke="#354ff5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</aside>
		</div>
	</div>
</section>

<style>
	.c-sec {
		background: var(--color-bg);
	}

	.c-sec-header {
		text-align: center;
		max-width: 760px;
		margin: 0 auto 3rem;
	}

	.c-sec-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3.2vw, 2.625rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0;
		font-weight: 700;
	}

	.c-sec-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(1.25rem, 2vw, 2rem);
		align-items: stretch;
		max-width: 1100px;
		margin: 0 auto;
	}

	.c-sec-copy-card {
		background: var(--color-bg-tint);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-lg);
		padding: clamp(2rem, 3vw, 2.75rem);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.c-sec-body {
		font-size: 1.0625rem;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin: 0 0 1.25rem;
	}

	.c-sec-body:last-of-type {
		margin-bottom: 0;
	}

	.c-sec-body :global(a) {
		color: var(--color-blue);
		font-weight: 500;
		border-bottom: 2px solid currentColor;
	}

	.c-sec-list-card {
		background: var(--color-bg);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-lg);
		padding: clamp(2rem, 3vw, 2.75rem);
		box-shadow: var(--shadow-card);
	}

	.c-sec-card-title {
		font-family: var(--font-heading);
		font-size: 1.375rem;
		color: var(--color-text);
		margin: 0 0 1.5rem;
		font-weight: 700;
	}

	.c-sec-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.c-sec-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.875rem;
		font-size: 1rem;
		line-height: 1.5;
		color: var(--color-text);
	}

	.c-sec-list svg {
		flex-shrink: 0;
		margin-top: 0.125rem;
	}

	@media (max-width: 860px) {
		.c-sec-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
