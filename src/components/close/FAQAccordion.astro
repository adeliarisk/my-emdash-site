---
interface FAQ {
	q: string;
	a: string | string[]; // single paragraph or array of paragraphs
}

interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	faqs: FAQ[];
}

const { eyebrow, title, subtitle, faqs } = Astro.props;

function asParagraphs(a: string | string[]): string[] {
	return Array.isArray(a) ? a : [a];
}
---

<section class="c-faq ar-section">
	<div class="ar-container-narrow">
		<header class="c-faq-header">
			{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
			<h2 class="c-faq-title">{title}</h2>
			{subtitle && <p class="c-faq-subtitle">{subtitle}</p>}
		</header>
		<div class="c-faq-list">
			{faqs.map((f, i) => (
				<details class="c-faq-item" open={i === 0}>
					<summary class="c-faq-q">
						<span>{f.q}</span>
						<svg class="c-faq-chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M6 9l6 6 6-6" />
						</svg>
					</summary>
					<div class="c-faq-a">
						{asParagraphs(f.a).map((p) => (
							<p>{p}</p>
						))}
					</div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.c-faq-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.c-faq-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3.3vw, 2.8125rem); /* 28 → 45px — matches source H2 */
		line-height: 1.12;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0 0 1rem;
		font-weight: 700;
	}

	.c-faq-subtitle {
		font-size: 1.0625rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.c-faq-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.c-faq-item {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
		transition: box-shadow 200ms ease, border-color 200ms ease;
	}

	.c-faq-item[open] {
		box-shadow: var(--shadow-card);
		border-color: var(--color-border);
	}

	.c-faq-q {
		list-style: none;
		cursor: pointer;
		padding: 1.5rem 1.75rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		font-family: var(--font-heading);
		font-size: 1.25rem; /* 20px */
		font-weight: 700;
		color: var(--color-text);
		line-height: 1.3;
		transition: color 180ms ease;
	}

	.c-faq-q::-webkit-details-marker {
		display: none;
	}

	.c-faq-q:hover {
		color: var(--color-blue);
	}

	.c-faq-chevron {
		flex-shrink: 0;
		color: var(--color-blue);
		transition: transform 240ms ease;
	}

	.c-faq-item[open] .c-faq-chevron {
		transform: rotate(180deg);
	}

	.c-faq-a {
		padding: 0 1.75rem 1.75rem;
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.c-faq-a p {
		margin: 0 0 1rem;
		font-size: 1rem;
	}

	.c-faq-a p:last-child {
		margin-bottom: 0;
	}

	@media (max-width: 640px) {
		.c-faq-q {
			padding: 1.25rem 1.25rem;
			font-size: 1rem;
		}
		.c-faq-a {
			padding: 0 1.25rem 1.25rem;
		}
	}
</style>
