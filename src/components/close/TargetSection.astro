---
interface Props {
	eyebrow?: string;
	title: string;
	body: string;
	listTitle: string;
	items: string[];
	footer?: string;
	backgroundImage?: string;
}

const {
	eyebrow,
	title,
	body,
	listTitle,
	items,
	footer,
	backgroundImage,
} = Astro.props;
---

<section class="c-target ar-section">
	<div class="ar-container">
		<header class="c-target-header">
			{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
			<h2 class="c-target-title">{title}</h2>
			<p class="c-target-body">{body}</p>
		</header>

		<div class="c-target-grid">
			{backgroundImage && (
				<div class="c-target-photo-wrap">
					<img
						src={backgroundImage}
						alt="Cybersecurity monitoring illustration"
						loading="lazy"
					/>
					<div class="c-target-photo-tint" aria-hidden="true"></div>
				</div>
			)}
			<aside class="c-target-card">
				<h3 class="c-target-list-title">{listTitle}</h3>
				<ul class="c-target-list">
					{items.map((item) => (
						<li>
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
								<rect x="1" y="1" width="18" height="18" rx="4" fill="#354ff5" fill-opacity="0.12" stroke="#354ff5" stroke-width="1.5"/>
								<path d="M6 10l3 3 5-6" stroke="#354ff5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</aside>
		</div>

		{footer && <p class="c-target-footer">{footer}</p>}
	</div>
</section>

<style>
	.c-target {
		background: var(--color-bg);
	}

	.c-target-header {
		text-align: center;
		max-width: 760px;
		margin: 0 auto 3rem;
	}

	.c-target-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3.3vw, 2.8125rem); /* 28 → 45px — matches source H2 */
		line-height: 1.12;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0 0 1.25rem;
		font-weight: 700;
	}

	.c-target-body {
		font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
		line-height: 1.65;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.c-target-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 4vw, 4rem);
		align-items: center;
		max-width: 1100px;
		margin: 0 auto;
	}

	.c-target-photo-wrap {
		position: relative;
		border-radius: var(--radius-lg);
		overflow: hidden;
		aspect-ratio: 4 / 3;
		box-shadow: var(--shadow-card);
	}

	.c-target-photo-wrap img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.c-target-photo-tint {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(18, 38, 58, 0.45) 0%, rgba(28, 54, 223, 0.35) 100%);
		mix-blend-mode: multiply;
		pointer-events: none;
	}

	.c-target-card {
		background: var(--color-bg-subtle);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-lg);
		padding: clamp(2rem, 3vw, 2.75rem);
	}

	.c-target-list-title {
		font-family: var(--font-heading);
		font-size: 1.75rem; /* 28px */
		color: var(--color-text);
		margin: 0 0 1.5rem;
		font-weight: 700;
	}

	.c-target-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.c-target-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.875rem;
		font-size: 1rem;
		line-height: 1.5;
		color: var(--color-text);
	}

	.c-target-list svg {
		flex-shrink: 0;
		margin-top: 0.125rem;
	}

	.c-target-footer {
		max-width: 760px;
		margin: 3rem auto 0;
		text-align: center;
		font-size: 1rem;
		line-height: 1.65;
		color: var(--color-text-secondary);
		font-style: italic;
	}

	@media (max-width: 880px) {
		.c-target-grid {
			grid-template-columns: 1fr;
		}
		.c-target-photo-wrap {
			max-width: 480px;
			margin: 0 auto;
			aspect-ratio: 16 / 10;
		}
	}
</style>
