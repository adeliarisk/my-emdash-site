---
interface Column {
	title: string;
	items: string[];
	tone?: "danger" | "positive" | "neutral";
}

interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	footnote?: string;
	left: Column;
	right: Column;
	dark?: boolean;
}

const {
	eyebrow,
	title,
	subtitle,
	footnote,
	left,
	right,
	dark = false,
} = Astro.props;

// Pair the items into rows for a true table-style comparison
const rowCount = Math.max(left.items.length, right.items.length);
const rows: Array<{ left: string; right: string }> = [];
for (let i = 0; i < rowCount; i++) {
	rows.push({
		left: left.items[i] || "",
		right: right.items[i] || "",
	});
}
---

<section class={`c-cmp ar-section ${dark ? "c-cmp-dark" : "ar-section-tinted"}`}>
	<div class="ar-container-narrow">
		<header class="c-cmp-header">
			{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
			<h2 class="c-cmp-title">{title}</h2>
			{subtitle && <p class="c-cmp-subtitle">{subtitle}</p>}
		</header>

		<div class="c-cmp-table">
			<div class={`c-cmp-row c-cmp-header-row`}>
				<div class={`c-cmp-cell c-cmp-head c-cmp-col-${left.tone || "neutral"}`}>
					{left.title}
				</div>
				<div class={`c-cmp-cell c-cmp-head c-cmp-col-${right.tone || "neutral"}`}>
					{right.title}
				</div>
			</div>
			{rows.map((row, i) => (
				<div class="c-cmp-row">
					<div class={`c-cmp-cell c-cmp-col-${left.tone || "neutral"}`}>
						{row.left && (
							<>
								<svg class="c-cmp-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
									<path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
								<span>{row.left}</span>
							</>
						)}
					</div>
					<div class={`c-cmp-cell c-cmp-col-${right.tone || "neutral"}`}>
						{row.right && (
							<>
								<svg class="c-cmp-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
									<path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
								<span>{row.right}</span>
							</>
						)}
					</div>
				</div>
			))}
		</div>

		{footnote && <p class="c-cmp-footnote">{footnote}</p>}
	</div>
</section>

<style>
	.c-cmp-dark {
		background: var(--gradient-hero);
		color: var(--color-on-accent);
		position: relative;
		overflow: hidden;
	}

	.c-cmp-dark::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
		background-size: 48px 48px;
		pointer-events: none;
	}

	.c-cmp-header {
		max-width: 820px;
		margin: 0 auto 2.5rem;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.c-cmp-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3vw, 2.625rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: inherit;
		margin: 0 0 1rem;
		font-weight: 700;
	}

	.c-cmp-dark .c-cmp-title {
		color: var(--color-on-accent);
	}

	.c-cmp-subtitle {
		font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.c-cmp-dark .c-cmp-subtitle {
		color: rgba(255, 255, 255, 0.82);
	}

	.c-cmp-table {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		position: relative;
		z-index: 1;
	}

	.c-cmp-dark .c-cmp-table {
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.14);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}

	.c-cmp-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
	}

	.c-cmp-row:not(:last-child) {
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.c-cmp-dark .c-cmp-row:not(:last-child) {
		border-bottom-color: rgba(255, 255, 255, 0.1);
	}

	.c-cmp-cell {
		padding: 1.125rem 1.5rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1rem;
		line-height: 1.4;
		color: var(--color-text);
		min-height: 60px;
	}

	.c-cmp-dark .c-cmp-cell {
		color: rgba(255, 255, 255, 0.92);
	}

	.c-cmp-cell:first-child {
		border-right: 1px solid var(--color-border-subtle);
	}

	.c-cmp-dark .c-cmp-cell:first-child {
		border-right-color: rgba(255, 255, 255, 0.1);
	}

	.c-cmp-head {
		font-family: var(--font-heading);
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--color-text);
		background: var(--color-bg-subtle);
		min-height: 64px;
	}

	.c-cmp-dark .c-cmp-head {
		background: rgba(255, 255, 255, 0.08);
		color: var(--color-on-accent);
	}

	.c-cmp-col-danger .c-cmp-arrow {
		color: #e4476b;
	}

	.c-cmp-col-positive .c-cmp-arrow {
		color: #354ff5;
	}

	.c-cmp-col-neutral .c-cmp-arrow {
		color: var(--color-muted);
	}

	.c-cmp-dark .c-cmp-col-positive .c-cmp-arrow {
		color: #8faaff;
	}

	.c-cmp-dark .c-cmp-col-danger .c-cmp-arrow {
		color: #ff7a9c;
	}

	.c-cmp-dark .c-cmp-col-neutral .c-cmp-arrow {
		color: rgba(255, 255, 255, 0.5);
	}

	.c-cmp-head .c-cmp-arrow {
		display: none;
	}

	.c-cmp-arrow {
		flex-shrink: 0;
	}

	.c-cmp-footnote {
		max-width: 820px;
		margin: 2.5rem auto 0;
		text-align: center;
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		font-style: italic;
		position: relative;
		z-index: 1;
	}

	.c-cmp-dark .c-cmp-footnote {
		color: rgba(255, 255, 255, 0.72);
	}

	@media (max-width: 640px) {
		.c-cmp-cell {
			padding: 0.875rem 1rem;
			font-size: 0.9375rem;
			min-height: 52px;
		}
		.c-cmp-head {
			font-size: 1rem;
			min-height: 56px;
		}
	}
</style>
