---
interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	ctaLabel: string;
	ctaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
}

const {
	eyebrow,
	title,
	subtitle,
	ctaLabel,
	ctaHref = "#",
	secondaryCtaLabel,
	secondaryCtaHref = "#",
} = Astro.props;
---

<section class="c-cta">
	<div class="c-cta-bg" aria-hidden="true"></div>
	<div class="c-cta-inner ar-container">
		{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
		<h2 class="c-cta-title">{title}</h2>
		{subtitle && <p class="c-cta-subtitle">{subtitle}</p>}
		<div class="c-cta-buttons">
			<a href={ctaHref} class="ar-btn ar-btn-primary">
				{ctaLabel}
				<svg width="18" height="12" viewBox="0 0 18 12" fill="none" aria-hidden="true">
					<path d="M12 1L17 6M17 6L12 11M17 6H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>
			{secondaryCtaLabel && (
				<a href={secondaryCtaHref} class="ar-btn ar-btn-ghost">
					{secondaryCtaLabel}
				</a>
			)}
		</div>
	</div>
</section>

<style>
	.c-cta {
		position: relative;
		overflow: hidden;
		padding: clamp(4rem, 7vw, 6rem) 0;
		color: var(--color-on-accent);
		text-align: center;
	}

	.c-cta-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		background: var(--gradient-hero);
	}

	.c-cta-bg::after {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
		background-size: 48px 48px;
	}

	.c-cta-inner {
		position: relative;
		z-index: 1;
		max-width: 820px !important;
	}

	.c-cta-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3.3vw, 2.8125rem); /* 28 → 45px — matches source H2 */
		line-height: 1.12;
		letter-spacing: -0.02em;
		color: var(--color-on-accent);
		margin: 0 0 1rem;
		font-weight: 700;
	}

	.c-cta-subtitle {
		font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.85);
		margin: 0 0 2.25rem;
	}

	.c-cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}
</style>
