---
interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	ctaLabel: string;
	ctaHref?: string;
}

const { eyebrow, title, subtitle, ctaLabel, ctaHref = "#" } = Astro.props;
---

<section class="c-cta">
	<div class="c-cta-bg" aria-hidden="true"></div>
	<div class="c-cta-inner close-container">
		{eyebrow && <span class="close-eyebrow">{eyebrow}</span>}
		<h2 class="c-cta-title">{title}</h2>
		{subtitle && <p class="c-cta-subtitle">{subtitle}</p>}
		<a href={ctaHref} class="close-btn close-btn-primary c-cta-button">
			{ctaLabel}
			<svg width="18" height="12" viewBox="0 0 18 12" fill="none" aria-hidden="true">
				<path d="M12 1L17 6M17 6L12 11M17 6H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
	</div>
</section>

<style>
	.c-cta {
		position: relative;
		overflow: hidden;
		padding: clamp(4rem, 7vw, 6rem) var(--close-gutter);
		color: var(--close-white);
		text-align: center;
	}

	.c-cta-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		background: var(--close-grad-hero-mesh);
	}

	.c-cta-inner {
		position: relative;
		z-index: 1;
		max-width: 760px;
	}

	.c-cta-title {
		font-family: var(--close-font-heading);
		font-size: var(--close-h2);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--close-white);
		margin: 0 0 1rem;
		font-weight: 700;
	}

	.c-cta-subtitle {
		font-size: var(--close-lead);
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.85);
		margin: 0 0 2.25rem;
	}

	.c-cta-button {
		margin: 0 auto;
	}
</style>
