---
interface Stat {
	before: string;
	after: string;
	label: string;
	description: string;
}

interface Props {
	eyebrow?: string;
	title?: string;
	stats: Stat[];
	dark?: boolean;
}

const { eyebrow, title, stats, dark = false } = Astro.props;
---

<section class={`c-stats ${dark ? "c-stats-dark" : ""}`}>
	<div class="close-container">
		{(eyebrow || title) && (
			<header class="c-stats-header">
				{eyebrow && <span class="close-eyebrow">{eyebrow}</span>}
				{title && <h2 class="c-stats-title">{title}</h2>}
			</header>
		)}
		<div class="c-stats-grid">
			{stats.map((s) => (
				<article class="c-stats-card">
					<div class="c-stats-transform">
						<span class="c-stats-before">{s.before}</span>
						<svg width="28" height="16" viewBox="0 0 28 16" fill="none" aria-hidden="true">
							<path d="M1 8H26M26 8L20 2M26 8L20 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						<span class="c-stats-after">{s.after}</span>
					</div>
					<h3 class="c-stats-label">{s.label}</h3>
					<p class="c-stats-desc">{s.description}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.c-stats {
		padding: var(--close-section-y) var(--close-gutter);
		background: var(--close-white);
	}

	.c-stats-dark {
		background: var(--close-grad-hero-mesh);
		color: var(--close-white);
	}

	.c-stats-dark :global(.close-eyebrow) {
		color: #8faaff;
	}

	.c-stats-header {
		max-width: 760px;
		margin: 0 auto 3rem;
		text-align: center;
	}

	.c-stats-title {
		font-family: var(--close-font-heading);
		font-size: var(--close-h2);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: inherit;
		margin: 0;
		font-weight: 700;
	}

	.c-stats-dark .c-stats-title {
		color: var(--close-white);
	}

	.c-stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(1.25rem, 2vw, 2rem);
	}

	.c-stats-card {
		background: var(--close-white);
		border-radius: var(--close-radius-card);
		padding: 2.25rem 2rem;
		box-shadow: var(--close-shadow-card);
		transition:
			transform 240ms ease,
			box-shadow 240ms ease;
	}

	.c-stats-dark .c-stats-card {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		box-shadow: none;
	}

	.c-stats-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--close-shadow-card-hover);
	}

	.c-stats-transform {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 1.25rem;
		color: var(--close-blue);
	}

	.c-stats-dark .c-stats-transform {
		color: #8faaff;
	}

	.c-stats-before {
		font-family: var(--close-font-heading);
		font-size: 2rem;
		font-weight: 700;
		color: var(--close-muted);
		text-decoration: line-through;
		text-decoration-color: var(--close-muted);
		text-decoration-thickness: 2px;
	}

	.c-stats-after {
		font-family: var(--close-font-heading);
		font-size: clamp(2.75rem, 5vw, 4rem);
		font-weight: 700;
		color: var(--close-blue);
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.c-stats-dark .c-stats-after {
		color: #ffffff;
	}

	.c-stats-dark .c-stats-before {
		color: rgba(255, 255, 255, 0.4);
		text-decoration-color: rgba(255, 255, 255, 0.4);
	}

	.c-stats-transform svg {
		flex-shrink: 0;
		align-self: center;
	}

	.c-stats-label {
		font-family: var(--close-font-heading);
		font-size: 1.25rem;
		line-height: 1.3;
		color: inherit;
		margin: 0 0 0.5rem;
		font-weight: 700;
	}

	.c-stats-dark .c-stats-label {
		color: var(--close-white);
	}

	.c-stats-desc {
		font-size: var(--close-small);
		line-height: 1.65;
		color: var(--close-ink-soft);
		margin: 0;
	}

	.c-stats-dark .c-stats-desc {
		color: rgba(255, 255, 255, 0.7);
	}

	@media (max-width: 880px) {
		.c-stats-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
