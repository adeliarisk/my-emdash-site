---
interface Stat {
	before: string;
	after: string;
	label: string;
	description: string;
	chart?: string; // optional chart image URL
}

interface Props {
	eyebrow?: string;
	title?: string;
	subtitle?: string;
	stats: Stat[];
	dark?: boolean;
}

const { eyebrow, title, subtitle, stats, dark = false } = Astro.props;
---

<section class={`c-stats ar-section ${dark ? "c-stats-dark" : ""}`}>
	<div class="ar-container">
		{(eyebrow || title || subtitle) && (
			<header class="c-stats-header">
				{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
				{title && <h2 class="c-stats-title">{title}</h2>}
				{subtitle && <p class="c-stats-subtitle">{subtitle}</p>}
			</header>
		)}
		<div class="c-stats-grid">
			{stats.map((s) => (
				<article class="c-stats-card">
					{s.chart ? (
						<div class="c-stats-chart" aria-hidden="true">
							<img src={s.chart} alt="" loading="lazy" />
						</div>
					) : (
						<div class="c-stats-bar" aria-hidden="true">
							<div class="c-stats-bar-track"></div>
							<div class="c-stats-bar-fill" style={`--fill: 100%;`}></div>
						</div>
					)}
					<div class="c-stats-transform">
						<span class="c-stats-before">{s.before}</span>
						<svg width="28" height="16" viewBox="0 0 28 16" fill="none" aria-hidden="true">
							<path d="M1 8H26M26 8L20 2M26 8L20 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						<span class="c-stats-after">{s.after}</span>
					</div>
					<h3 class="c-stats-label">{s.label}</h3>
					<p class="c-stats-desc">{s.description}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.c-stats-dark {
		background: var(--gradient-hero);
		color: var(--color-on-accent);
		position: relative;
		overflow: hidden;
	}

	.c-stats-dark::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
		background-size: 48px 48px;
		pointer-events: none;
	}

	.c-stats-header {
		max-width: 820px;
		margin: 0 auto 3rem;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.c-stats-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3.3vw, 2.8125rem); /* 28 → 45px — matches source H2 */
		line-height: 1.12;
		letter-spacing: -0.02em;
		color: inherit;
		margin: 0 0 1rem;
		font-weight: 700;
	}

	.c-stats-dark .c-stats-title {
		color: var(--color-on-accent);
	}

	.c-stats-subtitle {
		font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.82);
		margin: 0;
	}

	.c-stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(1.25rem, 2vw, 2rem);
		position: relative;
		z-index: 1;
	}

	.c-stats-card {
		background: var(--color-bg);
		border-radius: var(--radius-lg);
		padding: 2.25rem 2rem 2.5rem;
		box-shadow: var(--shadow-card);
		transition:
			transform 240ms ease,
			box-shadow 240ms ease;
	}

	.c-stats-dark .c-stats-card {
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		box-shadow: none;
	}

	.c-stats-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
	}

	.c-stats-dark .c-stats-card:hover {
		background: rgba(255, 255, 255, 0.09);
		box-shadow: none;
	}

	/* Small animated bar chart visual to match the source page's stat cards */
	.c-stats-chart {
		margin: -2.25rem -2rem 1.5rem;
		height: 180px;
		overflow: hidden;
		border-radius: var(--radius-lg) var(--radius-lg) 0 0;
		background: var(--color-bg);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.25rem;
	}

	.c-stats-chart img {
		max-width: 100%;
		max-height: 100%;
		width: auto;
		height: auto;
		object-fit: contain;
	}

	.c-stats-dark .c-stats-chart {
		background: rgba(255, 255, 255, 0.96);
	}

	.c-stats-bar {
		position: relative;
		height: 6px;
		margin-bottom: 1.5rem;
		overflow: hidden;
		border-radius: 999px;
	}

	.c-stats-bar-track {
		position: absolute;
		inset: 0;
		background: rgba(53, 79, 245, 0.12);
	}

	.c-stats-dark .c-stats-bar-track {
		background: rgba(255, 255, 255, 0.08);
	}

	.c-stats-bar-fill {
		position: absolute;
		top: 0;
		left: 0;
		width: var(--fill, 0%);
		height: 100%;
		background: var(--gradient-cta);
		border-radius: 999px;
	}

	.c-stats-transform {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 1.25rem;
		color: var(--color-blue);
	}

	.c-stats-dark .c-stats-transform {
		color: #8faaff;
	}

	.c-stats-before {
		font-family: var(--font-heading);
		font-size: 2rem;
		font-weight: 700;
		color: var(--color-muted);
		text-decoration: line-through;
		text-decoration-color: var(--color-muted);
		text-decoration-thickness: 2px;
	}

	.c-stats-dark .c-stats-before {
		color: rgba(255, 255, 255, 0.45);
		text-decoration-color: rgba(255, 255, 255, 0.45);
	}

	.c-stats-after {
		font-family: var(--font-heading);
		font-size: clamp(2.5rem, 4.5vw, 3.5rem);
		font-weight: 700;
		color: var(--color-blue);
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.c-stats-dark .c-stats-after {
		color: #ffffff;
	}

	.c-stats-transform svg {
		flex-shrink: 0;
		align-self: center;
	}

	.c-stats-label {
		font-family: var(--font-heading);
		font-size: 1.5rem; /* 24px */
		line-height: 1.25;
		color: inherit;
		margin: 0 0 0.625rem;
		font-weight: 700;
	}

	.c-stats-dark .c-stats-label {
		color: var(--color-on-accent);
	}

	.c-stats-desc {
		font-size: 0.9375rem;
		line-height: 1.65;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.c-stats-dark .c-stats-desc {
		color: rgba(255, 255, 255, 0.72);
	}

	@media (max-width: 880px) {
		.c-stats-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
