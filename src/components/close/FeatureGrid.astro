---
interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	items: string[];
}

const { eyebrow, title, subtitle, items } = Astro.props;

// Split items into two columns, left-to-right fill
const half = Math.ceil(items.length / 2);
const left = items.slice(0, half);
const right = items.slice(half);
---

<section class="c-fgrid ar-section">
	<div class="ar-container-narrow">
		<header class="c-fgrid-header">
			{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
			<h2 class="c-fgrid-title">{title}</h2>
			{subtitle && <p class="c-fgrid-subtitle">{subtitle}</p>}
		</header>
		<div class="c-fgrid-wrap">
			<div class="c-fgrid-col">
				{left.map((item) => (
					<div class="c-fgrid-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#354ff5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M5 12h14M13 5l7 7-7 7" />
						</svg>
						<span>{item}</span>
					</div>
				))}
			</div>
			<div class="c-fgrid-col">
				{right.map((item) => (
					<div class="c-fgrid-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#354ff5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M5 12h14M13 5l7 7-7 7" />
						</svg>
						<span>{item}</span>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.c-fgrid-header {
		max-width: 760px;
		margin: 0 auto 2.5rem;
		text-align: center;
	}

	.c-fgrid-title {
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 3vw, 2.625rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0 0 1rem;
		font-weight: 700;
		overflow-wrap: break-word;
	}

	.c-fgrid-subtitle {
		font-size: 1.0625rem;
		line-height: 1.65;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.c-fgrid-wrap {
		background: var(--color-bg-subtle);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-lg);
		padding: 1rem 1.5rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0 2rem;
	}

	.c-fgrid-col {
		display: flex;
		flex-direction: column;
	}

	.c-fgrid-item {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		padding: 0.875rem 0;
		font-size: 0.9375rem;
		line-height: 1.4;
		color: var(--color-text);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.c-fgrid-col .c-fgrid-item:last-child {
		border-bottom: none;
	}

	.c-fgrid-item svg {
		flex-shrink: 0;
		color: var(--color-blue);
	}

	@media (max-width: 720px) {
		.c-fgrid-wrap {
			grid-template-columns: 1fr;
			gap: 0;
			padding: 0.75rem 1.25rem;
		}
	}
</style>
