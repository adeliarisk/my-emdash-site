---
interface Testimonial {
	quote: string[]; // array of paragraphs
	name: string;
	role: string;
	firm: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	titleAccent?: string;
	testimonials: Testimonial[];
}

const { eyebrow, title, titleAccent, testimonials } = Astro.props;
---

<section class="c-testimonials ar-section ar-section-tinted">
	<div class="ar-container">
		<header class="c-testimonials-header">
			{eyebrow && <span class="ar-eyebrow">{eyebrow}</span>}
			<h2 class="c-testimonials-title">
				{title}
				{titleAccent && (
					<>
						<br />
						<span>{titleAccent}</span>
					</>
				)}
			</h2>
		</header>
		<div class="c-testimonials-scroller" data-scroller>
			<div class="c-testimonials-track">
				{testimonials.map((t, i) => (
					<article class="c-testimonial-card" data-slide={i}>
						<svg class="c-testimonial-quote-mark" width="56" height="42" viewBox="0 0 56 42" fill="none" aria-hidden="true">
							<path d="M0 42V24C0 10.7452 10.7452 0 24 0V10C14.0589 10 6 18.0589 6 28V42H0Z M32 42V24C32 10.7452 42.7452 0 56 0V10C46.0589 10 38 18.0589 38 28V42H32Z" fill="#354FF5" fill-opacity="0.18"/>
						</svg>
						<div class="c-testimonial-stars" aria-label="5 out of 5 stars">
							{[0, 1, 2, 3, 4].map(() => (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
								</svg>
							))}
						</div>
						{t.quote.map((p) => (
							<p class="c-testimonial-quote">{p}</p>
						))}
						<div class="c-testimonial-attribution">
							<div class="c-testimonial-avatar" aria-hidden="true">
								{t.name.charAt(0)}
							</div>
							<div class="c-testimonial-info">
								<span class="c-testimonial-name">{t.name}</span>
								<span class="c-testimonial-role">{t.role}</span>
								<span class="c-testimonial-firm">{t.firm}</span>
							</div>
						</div>
					</article>
				))}
			</div>
			{testimonials.length > 1 && (
				<div class="c-testimonials-dots" role="tablist" aria-label="Testimonials">
					{testimonials.map((_, i) => (
						<button
							type="button"
							class={`c-testimonials-dot ${i === 0 ? "is-active" : ""}`}
							data-dot={i}
							aria-label={`Show testimonial ${i + 1}`}
						></button>
					))}
				</div>
			)}
		</div>
	</div>
</section>

<script>
	// Simple scroll-snap + dot indicator controller
	const root = document.querySelector<HTMLElement>("[data-scroller]");
	if (root) {
		const track = root.querySelector<HTMLElement>(".c-testimonials-track");
		const dots = Array.from(root.querySelectorAll<HTMLButtonElement>(".c-testimonials-dot"));
		const slides = track
			? Array.from(track.querySelectorAll<HTMLElement>(".c-testimonial-card"))
			: [];

		function activate(index: number) {
			dots.forEach((d, i) => d.classList.toggle("is-active", i === index));
		}

		dots.forEach((dot) => {
			dot.addEventListener("click", () => {
				const idx = Number(dot.dataset.dot);
				const target = slides[idx];
				if (target && track) {
					track.scrollTo({ left: target.offsetLeft - track.offsetLeft, behavior: "smooth" });
				}
			});
		});

		if (track && slides.length > 1) {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.intersectionRatio > 0.6) {
							const idx = Number((entry.target as HTMLElement).dataset.slide);
							if (!Number.isNaN(idx)) activate(idx);
						}
					});
				},
				{ root: track, threshold: [0.6] }
			);
			slides.forEach((s) => observer.observe(s));
		}
	}
</script>

<style>
	.c-testimonials-header {
		text-align: center;
		max-width: 820px;
		margin: 0 auto 3rem;
	}

	.c-testimonials-title {
		font-family: var(--font-heading);
		font-size: clamp(1.75rem, 3.3vw, 2.8125rem); /* 28 → 45px — matches source H2 */
		line-height: 1.12;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0;
		font-weight: 700;
	}

	.c-testimonials-title span {
		color: var(--color-blue);
	}

	.c-testimonials-scroller {
		position: relative;
	}

	.c-testimonials-track {
		display: flex;
		gap: clamp(1rem, 2vw, 2rem);
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		scroll-behavior: smooth;
		-webkit-overflow-scrolling: touch;
		padding: 0.5rem 0 2rem;
		scrollbar-width: none;
	}

	.c-testimonials-track::-webkit-scrollbar {
		display: none;
	}

	.c-testimonial-card {
		scroll-snap-align: center;
		flex: 0 0 min(760px, 86vw);
		background: var(--color-bg);
		border-radius: var(--radius-lg);
		padding: clamp(2rem, 4vw, 3.5rem);
		box-shadow: var(--shadow-card);
		position: relative;
		display: flex;
		flex-direction: column;
	}

	.c-testimonial-quote-mark {
		margin-bottom: 1rem;
	}

	.c-testimonial-stars {
		display: flex;
		gap: 0.25rem;
		color: #ffb93a;
		margin-bottom: 1.5rem;
	}

	.c-testimonial-quote {
		font-size: 1.0625rem;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin: 0 0 1.25rem;
	}

	.c-testimonial-quote:last-of-type {
		margin-bottom: 2rem;
	}

	.c-testimonial-attribution {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: auto;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border-subtle);
	}

	.c-testimonial-avatar {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		background: var(--gradient-cta);
		color: var(--color-on-accent);
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 700;
		flex-shrink: 0;
	}

	.c-testimonial-info {
		display: flex;
		flex-direction: column;
		line-height: 1.4;
	}

	.c-testimonial-name {
		font-weight: 700;
		color: var(--color-text);
		font-size: 1rem;
	}

	.c-testimonial-role {
		font-size: 0.875rem;
		color: var(--color-blue);
		font-weight: 500;
	}

	.c-testimonial-firm {
		font-size: 0.8125rem;
		color: var(--color-muted);
	}

	.c-testimonials-dots {
		display: flex;
		gap: 0.625rem;
		justify-content: center;
		margin-top: 0.5rem;
	}

	.c-testimonials-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		border: none;
		background: var(--color-border);
		cursor: pointer;
		padding: 0;
		transition: background 180ms ease, width 180ms ease;
	}

	.c-testimonials-dot.is-active {
		background: var(--color-blue);
		width: 32px;
		border-radius: 999px;
	}
</style>
