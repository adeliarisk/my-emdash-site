---
interface Feature {
	icon: string; // svg path d=""
	title: string;
	description: string;
}

interface Props {
	eyebrow?: string;
	title?: string;
	subtitle?: string;
	features: Feature[];
	tinted?: boolean;
}

const { eyebrow, title, subtitle, features, tinted = false } = Astro.props;
---

<section class={`c-feat ${tinted ? "c-feat-tinted" : ""}`}>
	<div class="close-container">
		{(eyebrow || title || subtitle) && (
			<header class="c-feat-header">
				{eyebrow && <span class="close-eyebrow">{eyebrow}</span>}
				{title && <h2 class="c-feat-title">{title}</h2>}
				{subtitle && <p class="c-feat-subtitle">{subtitle}</p>}
			</header>
		)}
		<div class="c-feat-grid">
			{features.map((f) => (
				<article class="c-feat-card">
					<div class="c-feat-icon">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d={f.icon} />
						</svg>
					</div>
					<h3 class="c-feat-card-title">{f.title}</h3>
					<p class="c-feat-card-desc">{f.description}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.c-feat {
		padding: var(--close-section-y) var(--close-gutter);
		background: var(--close-white);
	}

	.c-feat-tinted {
		background: var(--close-surface);
	}

	.c-feat-header {
		max-width: 760px;
		margin: 0 auto 3.5rem;
		text-align: center;
	}

	.c-feat-title {
		font-family: var(--close-font-heading);
		font-size: var(--close-h2);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--close-ink);
		margin: 0 0 1rem;
		font-weight: 700;
	}

	.c-feat-subtitle {
		font-size: var(--close-lead);
		line-height: 1.6;
		color: var(--close-ink-soft);
		margin: 0;
	}

	.c-feat-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(1.25rem, 2vw, 2rem);
	}

	.c-feat-card {
		background: var(--close-white);
		border-radius: var(--close-radius-card);
		padding: 2.25rem 2rem 2.5rem;
		box-shadow: var(--close-shadow-card);
		transition:
			transform 240ms ease,
			box-shadow 240ms ease;
	}

	.c-feat-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--close-shadow-card-hover);
	}

	.c-feat-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		border-radius: 14px;
		background: var(--close-surface-alt);
		color: var(--close-blue);
		margin-bottom: 1.5rem;
	}

	.c-feat-card-title {
		font-family: var(--close-font-heading);
		font-size: 1.375rem;
		line-height: 1.25;
		color: var(--close-ink);
		margin: 0 0 0.75rem;
		font-weight: 700;
	}

	.c-feat-card-desc {
		font-size: var(--close-small);
		line-height: 1.65;
		color: var(--close-ink-soft);
		margin: 0;
	}

	@media (max-width: 880px) {
		.c-feat-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
